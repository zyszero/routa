{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-tool-permission.js"
          },
          {
            "type": "command",
            "command": "bash ./crates/harness-monitor/scripts/run-codex-hook.sh PreToolUse"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|Read|Grep|Glob|Search|LS",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./crates/harness-monitor/scripts/run-codex-hook.sh PreToolUse"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./crates/harness-monitor/scripts/run-codex-hook.sh PostToolUse"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|Read|Grep|Glob|Search|LS",
        "hooks": [
          {
            "type": "command",
            "command": "bash ./crates/harness-monitor/scripts/run-codex-hook.sh PostToolUse"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-git-control-plane.js"
          },
          {
            "type": "command",
            "command": "bash ./crates/harness-monitor/scripts/run-codex-hook.sh SessionStart"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-prompt-policy.js"
          },
          {
            "type": "command",
            "command": "bash ./crates/harness-monitor/scripts/run-codex-hook.sh UserPromptSubmit"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ./crates/harness-monitor/scripts/run-codex-hook.sh Stop"
          }
        ]
      }
    ]
  }
}
