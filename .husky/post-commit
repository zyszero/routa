#!/usr/bin/env sh
# Post-commit hook: report file budget regressions without blocking incremental refactors

# Skip if SKIP_HOOKS is set (for emergency commits)
if [ -n "$SKIP_HOOKS" ]; then
  echo "⚠️  SKIP_HOOKS is set, skipping post-commit checks"
  exit 0
fi

changed_files="$(git diff-tree --root --no-commit-id --name-only -r HEAD)"
if [ -z "$changed_files" ]; then
  exit 0
fi

echo "📏 Checking file budgets for the latest commit..."
if ! command -v entrix >/dev/null 2>&1; then
  echo "⚠️  entrix command not found; skipping file budget check."
  echo "    Install/build the Rust entrix CLI to restore this post-commit guard."
  exit 0
fi

if ! entrix hook file-length \
  --config tools/entrix/file_budgets.pre_commit.json \
  --strict-limit \
  $changed_files; then
  echo "⚠️  File budget warning: this commit includes oversized staged files."
  echo "    Continue refactoring before push."
fi
