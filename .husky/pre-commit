# Pre-commit hook: Run lightweight local gate
# Full checks are done in pre-push and local validate paths

# Skip if SKIP_HOOKS is set (for emergency commits)
if [ -n "$SKIP_HOOKS" ]; then
  echo "⚠️  SKIP_HOOKS is set, skipping pre-commit checks"
  exit 0
fi

# Run lint phase through hook runtime profile.
node --import tsx tools/hook-runtime/src/cli.ts --profile pre-commit "$@"
